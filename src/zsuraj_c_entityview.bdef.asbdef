projection;
strict ( 2 );
use draft;
use side effects;

define behavior for ZSURAJ_C_ENTITYVIEW //alias <alias_name>
use etag
{
  use create;
  use update;
  use delete;

  use association _Address { create; with draft;}
  use action Activate;
  use action Discard ;
  use action Edit;
  use action Prepare;
  use action Resume;
}

define behavior for ZSURAJ_C_ADDR //alias <alias_name>
{
  use update;
  use delete;

  use association _Contact { with draft; }

}